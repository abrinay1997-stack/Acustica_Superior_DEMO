---
import '../styles/global.css';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
}

const {
  title,
  description = 'Soluciones acústicas: paneles acústicos, difusores, tratamiento acústico, trampas de bajo, aislamiento y control de ruido.',
  ogImage = '/Logo/LOGO.webp',
  ogUrl,
} = Astro.props;

const siteUrl = 'https://acusticasuperior.com';
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? siteUrl);

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Acústica Superior",
  "alternateName": "Acústica Superior Panamá",
  "description": "Empresa panameña especializada en ingeniería acústica y tratamiento acústico profesional. Adecuación acústica, aislamiento, balance frecuencial, control de ruido industrial y diseño acústico personalizado.",
  "url": "https://acusticasuperior.com",
  "telephone": "+50761399247",
  "email": "acusticasuperior@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "PA",
    "addressLocality": "Ciudad de Panamá",
    "addressRegion": "Panamá"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "addressCountry": "PA"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "08:00",
    "closes": "18:00"
  },
  "priceRange": "$$",
  "currenciesAccepted": "USD",
  "paymentAccepted": "Cash, Bank Transfer",
  "areaServed": {
    "@type": "Country",
    "name": "Panamá"
  },
  "serviceType": [
    "Adecuación Acústica",
    "Aislamiento Acústico",
    "Balance Frecuencial",
    "Control de Ruido Industrial",
    "Medición y Diseño Acústico",
    "Diseño Acústico Personalizado"
  ],
  "sameAs": [
    "https://www.instagram.com/acusticasuperior/",
    "https://www.facebook.com/acusticasuperior",
    "https://wa.me/50761399247"
  ]
};
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={ogUrl ?? canonicalURL} />
    <title>{title} | Acústica Superior</title>

    <!-- Open Graph -->
    <meta property="og:site_name" content="Acústica Superior" />
    <meta property="og:title" content={`${title} | Acústica Superior`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={String(ogUrl ?? canonicalURL)} />
    <meta property="og:locale" content="es_PA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Acústica Superior`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Fuentes optimizadas con display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Lexend:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  </head>
  <body>
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>
    <NavBar />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <script>
      const dot = document.getElementById('cursor-dot');
      const ring = document.getElementById('cursor-ring');
      let mouseX = 0, mouseY = 0;
      let ringX = 0, ringY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        dot.style.left = mouseX + 'px';
        dot.style.top = mouseY + 'px';
      });

      function animateRing() {
        ringX += (mouseX - ringX) * 0.12;
        ringY += (mouseY - ringY) * 0.12;
        ring.style.left = ringX + 'px';
        ring.style.top = ringY + 'px';
        requestAnimationFrame(animateRing);
      }
      animateRing();

      const interactives = document.querySelectorAll('a, button, [role="button"], input, textarea, select, label');
      interactives.forEach(el => {
        el.addEventListener('mouseenter', () => {
          dot.classList.add('hovering');
          ring.classList.add('hovering');
        });
        el.addEventListener('mouseleave', () => {
          dot.classList.remove('hovering');
          ring.classList.remove('hovering');
        });
      });

      document.addEventListener('mouseleave', () => { ring.style.opacity = '0'; });
      document.addEventListener('mouseenter', () => { ring.style.opacity = '1'; });
    </script>
  </body>
</html>
