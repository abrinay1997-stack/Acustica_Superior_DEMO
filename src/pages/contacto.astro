---
import Layout from '../layouts/Layout.astro';
import HeroInterno from '../components/HeroInterno.astro';
import ContactoForm from '../components/ContactoForm.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Contacto"
  description="Contacta a Acústica Superior para solicitar una cotización de tratamiento acústico en Panamá. WhatsApp, Instagram y formulario de contacto."
>
  <HeroInterno
    titulo="Contáctanos"
    subtitulo="Cuéntanos sobre tu proyecto y te respondemos en menos de 24 horas."
    imagen={`${base}/images/hero-contacto.webp`}
    breadcrumb="Contacto"
  />

  <section style="padding: 6rem 0">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

      <div id="contacto-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:3.5rem;align-items:start">

        <!-- Columna izquierda: Formulario -->
        <div>
          <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:0.875rem;font-family:'DM Sans',sans-serif">
            Escríbenos
          </p>
          <div style="width:2.5rem;height:2px;background:#FD9800;border-radius:2px;margin-bottom:1.5rem"></div>
          <h2 style="font-family:'Lexend',sans-serif;font-weight:900;color:#1f2937;font-size:clamp(1.5rem,2.5vw,2rem);letter-spacing:-0.02em;margin-bottom:0.75rem">
            Envíanos un mensaje
          </h2>
          <p style="font-size:0.9375rem;color:rgba(69,79,94,0.7);margin-bottom:2rem;line-height:1.65;font-family:'DM Sans',sans-serif">
            Cuéntanos sobre tu espacio y te preparamos una propuesta personalizada.
          </p>
          <ContactoForm />
        </div>

        <!-- Columna derecha: Canales de contacto -->
        <div>
          <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:0.875rem;font-family:'DM Sans',sans-serif">
            Encuéntranos aquí
          </p>
          <div style="width:2.5rem;height:2px;background:#FD9800;border-radius:2px;margin-bottom:1.5rem"></div>
          <h2 style="font-family:'Lexend',sans-serif;font-weight:900;color:#1f2937;font-size:clamp(1.5rem,2.5vw,2rem);letter-spacing:-0.02em;margin-bottom:0.75rem">
            Canales de contacto
          </h2>
          <p style="font-size:0.9375rem;color:rgba(69,79,94,0.7);margin-bottom:2rem;line-height:1.65;font-family:'DM Sans',sans-serif">
            Respuesta rápida por WhatsApp, también disponibles en redes sociales.
          </p>

          <div style="display:flex;flex-direction:column;gap:1rem">

            <!-- WhatsApp -->
            <a
              href="https://wa.me/50761399247"
              target="_blank"
              rel="noopener"
              style="display:flex;align-items:center;gap:1.25rem;background:#FFFFFF;border:1px solid rgba(37,211,102,0.25);border-radius:16px;padding:1.25rem 1.5rem;transition:border-color 0.3s,transform 0.3s,box-shadow 0.3s;text-decoration:none;box-shadow:0 2px 12px rgba(0,0,0,0.05)"
              onmouseenter="this.style.borderColor='rgba(37,211,102,0.5)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 16px 40px rgba(37,211,102,0.12)'"
              onmouseleave="this.style.borderColor='rgba(37,211,102,0.25)';this.style.transform='translateY(0)';this.style.boxShadow='0 2px 12px rgba(0,0,0,0.05)'"
            >
              <div style="width:3rem;height:3rem;border-radius:12px;background:rgba(37,211,102,0.1);border:1px solid rgba(37,211,102,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.818.487 3.52 1.338 4.992L2 22l5.15-1.322A9.956 9.956 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.95 7.95 0 01-4.051-1.107l-.29-.172-3.057.784.813-2.981-.188-.306A7.944 7.944 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
              </div>
              <div>
                <div style="font-weight:700;color:#1f2937;font-size:1rem;margin-bottom:0.25rem;font-family:'Lexend',sans-serif">WhatsApp</div>
                <div style="font-size:0.9375rem;color:rgba(69,79,94,0.65);font-family:'DM Sans',sans-serif">+507 6139 9247</div>
                <div style="font-size:0.75rem;color:rgba(69,79,94,0.45);margin-top:0.25rem;letter-spacing:0.03em;font-family:'DM Sans',sans-serif">Respuesta rápida · Lun–Sáb</div>
              </div>
            </a>

            <!-- Instagram -->
            <a
              href="https://www.instagram.com/acusticasuperior/"
              target="_blank"
              rel="noopener"
              style="display:flex;align-items:center;gap:1.25rem;background:#FFFFFF;border:1px solid rgba(225,48,108,0.2);border-radius:16px;padding:1.25rem 1.5rem;transition:border-color 0.3s,transform 0.3s,box-shadow 0.3s;text-decoration:none;box-shadow:0 2px 12px rgba(0,0,0,0.05)"
              onmouseenter="this.style.borderColor='rgba(225,48,108,0.45)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 16px 40px rgba(225,48,108,0.1)'"
              onmouseleave="this.style.borderColor='rgba(225,48,108,0.2)';this.style.transform='translateY(0)';this.style.boxShadow='0 2px 12px rgba(0,0,0,0.05)'"
            >
              <div style="width:3rem;height:3rem;border-radius:12px;background:rgba(225,48,108,0.07);border:1px solid rgba(225,48,108,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E1306C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </div>
              <div>
                <div style="font-weight:700;color:#1f2937;font-size:1rem;margin-bottom:0.25rem;font-family:'Lexend',sans-serif">Instagram</div>
                <div style="font-size:0.9375rem;color:rgba(69,79,94,0.65);font-family:'DM Sans',sans-serif">@acusticasuperior</div>
              </div>
            </a>

            <!-- Facebook -->
            <a
              href="https://www.facebook.com/acusticasuperior"
              target="_blank"
              rel="noopener"
              style="display:flex;align-items:center;gap:1.25rem;background:#FFFFFF;border:1px solid rgba(24,119,242,0.2);border-radius:16px;padding:1.25rem 1.5rem;transition:border-color 0.3s,transform 0.3s,box-shadow 0.3s;text-decoration:none;box-shadow:0 2px 12px rgba(0,0,0,0.05)"
              onmouseenter="this.style.borderColor='rgba(24,119,242,0.45)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 16px 40px rgba(24,119,242,0.1)'"
              onmouseleave="this.style.borderColor='rgba(24,119,242,0.2)';this.style.transform='translateY(0)';this.style.boxShadow='0 2px 12px rgba(0,0,0,0.05)'"
            >
              <div style="width:3rem;height:3rem;border-radius:12px;background:rgba(24,119,242,0.07);border:1px solid rgba(24,119,242,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </div>
              <div>
                <div style="font-weight:700;color:#1f2937;font-size:1rem;margin-bottom:0.25rem;font-family:'Lexend',sans-serif">Facebook</div>
                <div style="font-size:0.9375rem;color:rgba(69,79,94,0.65);font-family:'DM Sans',sans-serif">Acústica Superior</div>
              </div>
            </a>

            <!-- Ubicación -->
            <div
              style="display:flex;align-items:center;gap:1.25rem;background:#FFFFFF;border:1px solid rgba(253,152,0,0.2);border-radius:16px;padding:1.25rem 1.5rem;box-shadow:0 2px 12px rgba(0,0,0,0.05)"
            >
              <div style="width:3rem;height:3rem;border-radius:12px;background:rgba(253,152,0,0.08);border:1px solid rgba(253,152,0,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FD9800" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div style="font-weight:700;color:#1f2937;font-size:1rem;margin-bottom:0.25rem;font-family:'Lexend',sans-serif">Ubicación</div>
                <div style="font-size:0.9375rem;color:rgba(69,79,94,0.65);font-family:'DM Sans',sans-serif">Panamá, República de Panamá</div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 1023px) {
    #contacto-grid { grid-template-columns: 1fr !important; gap: 3rem !important; }
  }
</style>
