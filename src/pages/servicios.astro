---
import Layout from '../layouts/Layout.astro';
import HeroInterno from '../components/HeroInterno.astro';
import CTABanner from '../components/CTABanner.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const servicios = [
  {
    imagen: `${base}/images/Adecuación_acustica.webp`,
    titulo: 'Adecuación Acústica',
    descripcion: 'La adecuación acústica consiste en acondicionar un espacio para que el sonido se escuche claro, agradable y sin molestias. No se trata solo de reducir el ruido, sino de mejorar la calidad del sonido dentro de cada ambiente. Ideal para restaurantes, oficinas, salones de conferencia, auditorios, escuelas, iglesias y cualquier otro espacio que lo amerite.',
    beneficios: [
      'Análisis completo del espacio con medición calibrada',
      'Reducción de reverberación excesiva',
      'Mejora de la claridad del habla en salas de reunión',
      'Materiales de alta absorción con acabado estético',
      'Garantía de resultados medibles',
    ],
    id: 'adecuacion',
    numero: '01',
    flip: false,
  },
  {
    imagen: `${base}/images/Aislamiento_y_bloqueo_acustico.webp`,
    titulo: 'Aislamiento y Bloqueo Acústico',
    descripcion: 'El aislamiento acústico evita que el ruido entre o salga de un lugar. El bloqueo acústico, en cambio, impide que los sonidos se filtren o transmitan entre habitaciones o paredes. Ningún espacio es igual a otro, pero una vez hecho el análisis adecuado es posible aislar cualquier espacio comprendiendo la necesidad del cliente. Con estas soluciones, logramos que disfrutes de tranquilidad, privacidad y confort sonoro en tu espacio.',
    beneficios: [
      'Diseño de sistemas de masa-resorte para paredes',
      'Tratamiento de puntos de transmisión (puertas, ventanas)',
      'Desconexión estructural para control de impacto',
      'Cumplimiento de normativas de privacidad',
      'Soluciones para construcciones nuevas y retrofitting',
    ],
    id: 'aislamiento',
    numero: '02',
    flip: true,
  },
  {
    imagen: `${base}/images/Balance_frecuencial.webp`,
    titulo: 'Balance Frecuencial',
    descripcion: 'El balance frecuencial consiste en balancear los distintos rangos de frecuencias (low end, graves, medias bajas, medias, medias altas, altas y agudas). Cuando ese equilibrio no existe, la precisión en la toma de decisiones para lograr una buena mezcla y un mastering profesional se ve afectada. Con una buena medición y corrección, logramos que el sonido sea claro, agradable, natural y plano — ideal para estudio de música y sala de podcasts.',
    beneficios: [
      'Medición de respuesta en frecuencia (RTA, waterfall)',
      'Trampa de graves personalizada para bajos incontrolados',
      'Difusores cuadráticos para alta frecuencia',
      'Calibración de monitores de estudio',
      'Informe técnico detallado pre y post tratamiento',
    ],
    id: 'balance',
    numero: '03',
    flip: false,
  },
  {
    imagen: `${base}/images/Control_de_Ruido_Industrial.webp`,
    titulo: 'Control de Ruido Industrial',
    descripcion: 'Es el conjunto de técnicas, tecnologías y estrategias utilizadas para reducir o eliminar el ruido generado por procesos industriales, maquinaria o equipos en fábricas, plantas o talleres. Beneficios: previene pérdida auditiva y reduce el estrés laboral, mejora la productividad, evita multas por exceder los límites de ruido permitidos y crea un mejor ambiente laboral.',
    beneficios: [
      'Diagnóstico de niveles de presión sonora (dBA)',
      'Encapsulamiento de maquinaria ruidosa',
      'Barreras acústicas industriales',
      'Cumplimiento OSHA y normativas panameñas',
      'Reducción de quejas de vecinos y multas',
    ],
    id: 'ruido',
    numero: '04',
    flip: true,
  },
  {
    imagen: `${base}/images/Medición_y_diseño_acústico.webp`,
    titulo: 'Medición y Diseño Acústico',
    descripcion: 'La medición acústica nos permite conocer cómo se comporta el sonido en un espacio: si hay eco, ruido excesivo o pérdida de claridad. El diseño acústico es el paso siguiente: aplicar soluciones para que el lugar tenga un sonido claro, agradable y sin molestias.',
    beneficios: [
      'Medición de RT60 (tiempo de reverberación)',
      'Análisis de modos de sala (standing waves)',
      'Planos técnicos de solución acústica',
      'Modelado 3D del comportamiento acústico',
      'Propuesta detallada con presupuesto cerrado',
    ],
    id: 'medicion',
    numero: '05',
    flip: false,
  },
  {
    imagen: `${base}/images/hero-servicios.webp`,
    titulo: 'Diseño Acústico Personalizado',
    descripcion: 'Trabajamos de la mano contigo, escuchando tus ideas y necesidades para transformarlas en una realidad concreta y funcional. Co-creamos el tratamiento ideal para tu espacio: desde renders 3D hasta la selección de materiales premium, diseñando paneles exclusivos que integran perfectamente la ingeniería acústica con la estética de tu entorno.',
    beneficios: [
      'Renders 3D fotorrealistas del espacio tratado',
      'Selección de materiales premium con acabado decorativo',
      'Paneles personalizados en forma, textura y color',
      'Integración perfecta con el diseño de interiores existente',
      'Propuesta visual completa antes de iniciar el proyecto',
    ],
    id: 'diseno',
    numero: '06',
    flip: true,
  },
];
---
<Layout
  title="Servicios"
  description="Servicios de tratamiento acústico profesional en Panamá: adecuación acústica, aislamiento, balance frecuencial, control de ruido, medición acústica y diseño estético."
>
  <HeroInterno
    titulo="Nuestros Servicios"
    subtitulo="Soluciones acústicas diseñadas con precisión técnica para cada tipo de espacio."
    imagen={`${base}/images/hero-servicios.webp`}
    breadcrumb="Servicios"
  />

  <!-- Intro row -->
  <section id="servicios-intro" style="padding: 4rem 0 2rem">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem;text-align:center">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:0.75rem;font-family:'DM Sans',sans-serif">
        Nuestras especialidades
      </p>
      <h2 style="font-family:'Lexend',sans-serif;font-weight:900;color:#1f2937;font-size:clamp(1.75rem,3vw,2.5rem);letter-spacing:-0.02em;line-height:1.1;margin-bottom:1rem">
        Enfoque técnico, especializado y personalizado en:
      </h2>
      <p style="font-size:0.9375rem;color:rgba(69,79,94,0.7);max-width:38rem;line-height:1.65;margin:0 auto;font-family:'DM Sans',sans-serif">
        Paneles de acústica, difusores, trampas de bajo, reducción de superficies reflectantes, diseño acústico y estético, aislamiento y bloqueo acústico.
      </p>
    </div>
  </section>

  <!-- Servicios feature list alternado -->
  <section id="servicios-lista" style="padding:2rem 0 6rem">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem;display:flex;flex-direction:column;gap:5rem">

      {servicios.map((s) => (
        <div id={s.id} class="servicio-row" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">

          <!-- Imagen -->
          <div class={s.flip ? 'img-col img-col-flip' : 'img-col'} style="position:relative;border-radius:20px;overflow:hidden;border:1px solid rgba(0,0,0,0.08);box-shadow:0 16px 48px rgba(0,0,0,0.1)">
            <img
              src={s.imagen}
              alt={s.titulo}
              style="width:100%;height:22rem;object-fit:cover;display:block"
              loading="lazy"
            />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.4) 0%,transparent 50%)"></div>
            <div style="position:absolute;top:1rem;left:1rem;font-family:'Lexend',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.15em;color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.35);backdrop-filter:blur(8px);padding:0.25rem 0.625rem;border-radius:4px">
              {s.numero}
            </div>
          </div>

          <!-- Contenido -->
          <div class={s.flip ? 'txt-col txt-col-flip' : 'txt-col'}>
            <div style="width:2.5rem;height:2px;background:#FD9800;border-radius:2px;margin-bottom:1.25rem"></div>
            <h3 style="font-family:'Lexend',sans-serif;font-weight:800;font-size:clamp(1.5rem,2.5vw,2rem);color:#1f2937;margin-bottom:1rem;line-height:1.2;letter-spacing:-0.02em">
              {s.titulo}
            </h3>
            <p style="font-size:0.9375rem;line-height:1.75;color:rgba(69,79,94,0.8);margin-bottom:1.75rem;font-family:'DM Sans',sans-serif">
              {s.descripcion}
            </p>

            <ul style="display:flex;flex-direction:column;gap:0.625rem;margin-bottom:2rem">
              {s.beneficios.map(ben => (
                <li style="display:flex;align-items:flex-start;gap:0.75rem;font-size:0.875rem;color:rgba(69,79,94,0.75);line-height:1.5;font-family:'DM Sans',sans-serif">
                  <span style="color:#FD9800;font-size:0.75rem;margin-top:0.2rem;flex-shrink:0">◆</span>
                  {ben}
                </li>
              ))}
            </ul>

            <a
              href={`https://wa.me/50761399247?text=Hola,%20quiero%20cotizar%20el%20servicio%20de%20${encodeURIComponent(s.titulo)}`}
              target="_blank"
              rel="noopener"
              class="btn-primary"
              style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.9375rem"
            >
              Cotiza Con Nosotros →
            </a>
          </div>

        </div>
      ))}

    </div>
  </section>

  <CTABanner />
</Layout>

<style>
  /* Flip: imagen va a la derecha (orden 2), texto a la izquierda (orden 1) */
  .img-col-flip { order: 2; }
  .txt-col-flip { order: 1; }

  @media (max-width: 1023px) {
    .servicio-row {
      grid-template-columns: 1fr !important;
    }
    /* En mobile, imagen siempre arriba independientemente del flip */
    .img-col, .img-col-flip { order: 1 !important; }
    .txt-col, .txt-col-flip { order: 2 !important; }
  }
  @media (max-width: 767px) {
    #servicios-intro { padding: 2.5rem 0 1rem !important; }
    #servicios-lista { padding: 1.5rem 0 3.5rem !important; }
    #servicios-lista > div { gap: 3rem !important; }
    .servicio-row { gap: 1.75rem !important; }
    /* Reducir altura fija de imagen de servicio */
    .servicio-row img { height: 16rem !important; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray('.servicio-row').forEach((row: any) => {
    gsap.from(row, {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: row,
        start: 'top 85%',
      },
    });
  });
</script>
