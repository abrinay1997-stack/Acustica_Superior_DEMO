import ServiciosGrid from '../components/ServiciosGrid.astro';
import CTABanner from '../components/CTABanner.astro';
---
<Layout title="Servicios" description="Servicios de tratamiento acústico profesional en Panamá: adecuación acústica, aislamiento, balance frecuencial, control de ruido y medición acústica.">
