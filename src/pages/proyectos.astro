---
import Layout from '../layouts/Layout.astro';
import HeroInterno from '../components/HeroInterno.astro';
import ProyectosMasonry from '../components/ProyectosMasonry.astro';
import CTABanner from '../components/CTABanner.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const clientes = [
  'Flow La Música', 'Mista Bombo', 'Omar Alfano', 'Faster Musica',
  'Shok Multimedia', 'Rike Music', 'Javier Saavedra', 'Bk',
  'Eddy Lover', 'At Fat', 'Renan Delgado', 'Chino Gálvez',
  'Chiqui Dubs', 'La Manzana Estudio', 'Rafita', 'Smile Beats',
  'Dj Greg', 'Infinity Gun Club',
];
---
<Layout
  title="Proyectos"
  description="Proyectos de tratamiento acústico realizados por Acústica Superior en Panamá: estudios de grabación, salas corporativas y espacios industriales."
>
  <HeroInterno
    titulo="Algunos de Nuestros Proyectos"
    subtitulo="Cada espacio tiene su propia acústica. Aquí están algunas de nuestras transformaciones realizadas en Panamá."
    imagen={`${base}/images/Studio3.webp`}
    breadcrumb="Proyectos"
  />

  <!-- Intro -->
  <section style="padding: 4rem 0 2rem">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">
      <div style="margin-bottom:2rem">
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:0.75rem;font-family:'DM Sans',sans-serif">
          Portafolio
        </p>
        <h2 style="font-family:'Lexend',sans-serif;font-weight:900;color:#1f2937;font-size:clamp(1.75rem,3vw,2.5rem);letter-spacing:-0.02em;line-height:1.1;margin-bottom:1rem">
          Galería de proyectos
        </h2>
        <p style="font-size:0.9375rem;color:rgba(69,79,94,0.75);line-height:1.7;font-family:'DM Sans',sans-serif;max-width:52rem">
          Hemos tenido el privilegio de trabajar con algunos de los mejores artistas, productores, estudios de grabación e instalaciones de Panamá y Latinoamérica, logrando transformar sus espacios con tratamientos acústicos de alta calidad.
        </p>
      </div>
    </div>
  </section>

  <!-- Galería de fotos -->
  <ProyectosMasonry />

  <!-- Sección de clientes — debajo de la galería -->
  <section id="clientes-section" style="padding:4rem 0 5rem;background:#F9FAFB">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

      <!-- Header -->
      <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:2rem;flex-wrap:wrap">
        <div style="width:2.5rem;height:2px;background:#FD9800;border-radius:2px;flex-shrink:0"></div>
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;font-family:'DM Sans',sans-serif;margin:0">
          Algunos de nuestros Clientes
        </p>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:1.75rem;height:1.75rem;border-radius:50%;background:rgba(253,152,0,0.12);color:#FD9800;font-size:0.75rem;font-weight:700;font-family:'DM Sans',sans-serif;flex-shrink:0">
          {clientes.length}
        </span>
      </div>

      <!-- Pills grid — siempre visibles -->
      <div style="display:flex;flex-wrap:wrap;gap:0.625rem">
        {clientes.map(c => (
          <span
            class="client-pill"
            style="display:inline-flex;align-items:center;gap:0.375rem;padding:0.4375rem 1.125rem;border-radius:999px;border:1px solid rgba(0,0,0,0.1);background:#FFFFFF;font-size:0.8125rem;font-weight:500;color:rgb(69,79,94);font-family:'DM Sans',sans-serif;box-shadow:0 1px 4px rgba(0,0,0,0.06);transition:border-color 0.2s,color 0.2s,box-shadow 0.2s,transform 0.2s"
            onmouseenter="this.style.borderColor='rgba(253,152,0,0.5)';this.style.color='#FD9800';this.style.boxShadow='0 4px 12px rgba(253,152,0,0.12)';this.style.transform='translateY(-2px)'"
            onmouseleave="this.style.borderColor='rgba(0,0,0,0.1)';this.style.color='rgb(69,79,94)';this.style.boxShadow='0 1px 4px rgba(0,0,0,0.06)';this.style.transform='translateY(0)'"
          >
            <span style="width:5px;height:5px;background:#FD9800;border-radius:50%;flex-shrink:0;opacity:0.7"></span>
            {c}
          </span>
        ))}
      </div>

    </div>
  </section>

  <CTABanner />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Animar los pills al entrar en vista
  gsap.from('.client-pill', {
    y: 20,
    opacity: 0,
    stagger: 0.04,
    duration: 0.5,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '#clientes-section',
      start: 'top 85%',
    },
  });
</script>
