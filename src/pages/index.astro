---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatsStrip from '../components/StatsStrip.astro';
import ServiciosGrid from '../components/ServiciosGrid.astro';
import CTABanner from '../components/CTABanner.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Inicio"
  description="Acústica Superior: soluciones de tratamiento acústico profesional en Panamá. Paneles acústicos, aislamiento, balance frecuencial y diseño acústico para estudios y espacios corporativos."
>
  <Hero />
  <StatsStrip />

  <!-- Servicios preview -->
  <section style="padding: 6rem 0">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

      <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:3rem;flex-wrap:wrap;gap:1rem">
        <div>
          <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FDE817;margin-bottom:0.75rem">
            Lo que hacemos
          </p>
          <h2 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;color:white;font-size:clamp(1.75rem,3vw,2.5rem);line-height:1.15">
            Nuestros Servicios
          </h2>
        </div>
        <a href={`${base}/servicios`} style="color:#FDE817;font-size:0.9375rem;font-weight:600;display:inline-flex;align-items:center;gap:0.5rem;transition:gap 0.2s"
          onmouseenter="this.style.gap='0.75rem'" onmouseleave="this.style.gap='0.5rem'">
          Ver todos →
        </a>
      </div>

    </div>
    <ServiciosGrid />
  </section>

  <!-- Proyectos preview -->
  <section style="padding: 6rem 0; border-top: 1px solid rgba(255,255,255,0.06)">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

      <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:3rem;flex-wrap:wrap;gap:1rem">
        <div>
          <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FDE817;margin-bottom:0.75rem">
            Nuestro trabajo
          </p>
          <h2 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;color:white;font-size:clamp(1.75rem,3vw,2.5rem);line-height:1.15">
            Proyectos Realizados
          </h2>
        </div>
        <a href={`${base}/proyectos`} style="color:#FDE817;font-size:0.9375rem;font-weight:600;display:inline-flex;align-items:center;gap:0.5rem;transition:gap 0.2s"
          onmouseenter="this.style.gap='0.75rem'" onmouseleave="this.style.gap='0.5rem'">
          Ver galería completa →
        </a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.25rem">
        {[1, 2, 3, 4].map(n => (
          <a
            href={`${base}/proyectos`}
            style="position:relative;overflow:hidden;border-radius:16px;border:1px solid rgba(255,255,255,0.08);aspect-ratio:4/3;display:block;transition:border-color 0.3s,transform 0.3s"
            onmouseenter="this.style.borderColor='rgba(253,232,23,0.3)';this.style.transform='scale(1.01)'"
            onmouseleave="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='scale(1)'"
          >
            <img
              src={`${base}/images/Studio${n}.webp`}
              alt={`Studio ${n}`}
              style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s"
              loading="lazy"
            />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.5) 0%,transparent 50%)"></div>
            <div
              style="position:absolute;inset:0;display:flex;align-items:flex-end;padding:1.25rem;opacity:0;transition:opacity 0.3s"
              onmouseenter="this.style.opacity='1'"
              onmouseleave="this.style.opacity='0'"
            >
              <span style="font-family:'Plus Jakarta Sans',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.1em;color:rgba(255,255,255,0.8);background:rgba(0,0,0,0.5);backdrop-filter:blur(6px);padding:0.25rem 0.625rem;border-radius:4px">
                Studio {n}
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <CTABanner />
</Layout>
