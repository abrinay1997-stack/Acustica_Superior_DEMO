---
import Layout from '../layouts/Layout.astro';
import HeroInterno from '../components/HeroInterno.astro';
import CTABanner from '../components/CTABanner.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const valores = [
  {
    titulo: 'Precisión Técnica',
    descripcion: 'Utilizamos metodologías de medición acústica calibradas para garantizar resultados verificables y reproducibles.',
    numero: '01',
  },
  {
    titulo: 'Estética Superior',
    descripcion: 'Diseñamos soluciones que integran la técnica con la estética, mejorando visualmente cada espacio tratado.',
    numero: '02',
  },
  {
    titulo: 'Funcionalidad Total',
    descripcion: 'Cada solución está diseñada para el uso real del espacio, priorizando la funcionalidad a largo plazo.',
    numero: '03',
  },
];
---
<Layout
  title="Quiénes Somos"
  description="Acústica Superior: empresa panameña especializada en soluciones acústicas profesionales, tratamiento de espacios y diseño acústico personalizado."
>
  {/* TODO: revisar el texto "estética a nivel internacional" — el jefe quiere ajustarlo */}
  <HeroInterno
    titulo="Somos Acústica Superior"
    subtitulo="Diseñamos el sonido de tu espacio con precisión técnica y estética a nivel internacional."
    imagen={`${base}/images/hero-quienes-somos.webp`}
    breadcrumb="Quiénes Somos"
  />

  <!-- Historia section -->
  <section id="qs-historia" style="padding: 6rem 0; border-top: 1px solid rgba(0,0,0,0.06)">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">
      <div id="historia-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">

        <!-- Texto -->
        <div>
          <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:0.875rem;font-family:'DM Sans',sans-serif">
            Nuestra Historia
          </p>
          <div style="width:2.5rem;height:2px;background:linear-gradient(90deg,#FD9800,rgba(253,152,0,0.3));border-radius:2px;margin-bottom:1.5rem"></div>
          <h2 style="font-family:'Lexend',sans-serif;font-weight:900;color:#1f2937;font-size:clamp(1.875rem,3.5vw,2.75rem);line-height:1.1;letter-spacing:-0.02em;margin-bottom:1.75rem">
            Especialistas en acústica<br>con sede en Panamá.
          </h2>
          <div style="display:flex;flex-direction:column;gap:1.25rem">
            <p style="font-size:1rem;line-height:1.75;color:rgba(69,79,94,0.8);font-family:'DM Sans',sans-serif">
              Con más de 10 años de trayectoria en la producción musical, decidimos incursionar en el campo de la acústica en busca de la máxima calidad sonora. Descubrimos que, sin importar si el equipo de producción es de alta o baja gama, solo mediante un tratamiento acústico adecuado del espacio es posible aprovechar al máximo su potencial, logrando un balance frecuencial óptimo.
            </p>
            <p style="font-size:1rem;line-height:1.75;color:rgba(69,79,94,0.8);font-family:'DM Sans',sans-serif">
              Por eso, nos especializamos en ingeniería acústica arquitectónica, con el objetivo de analizar y diseñar soluciones personalizadas que permitan escuchar y trabajar el sonido con la mayor fidelidad posible.
            </p>
          </div>
        </div>

        <!-- Imagen -->
        <div style="position:relative;border-radius:20px;overflow:hidden;border:1px solid rgba(0,0,0,0.08);box-shadow:0 24px 60px rgba(0,0,0,0.12)">
          <img
            src={`${base}/images/quienes-somos-equipo.webp`}
            alt="Equipo Acústica Superior"
            style="width:100%;height:26rem;object-fit:cover;display:block"
            loading="lazy"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.4) 0%,transparent 50%)"></div>
          <!-- Badge sobre imagen -->
          <div style="position:absolute;bottom:1.25rem;left:1.25rem;background:rgba(255,255,255,0.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border:1px solid rgba(0,0,0,0.08);border-radius:12px;padding:0.875rem 1.25rem">
            <p style="font-size:0.75rem;font-weight:700;color:#FD9800;letter-spacing:0.08em;font-family:'Lexend',sans-serif">ACÚSTICA SUPERIOR</p>
            <p style="font-size:0.8125rem;color:rgba(69,79,94,0.7);margin-top:0.25rem;font-family:'DM Sans',sans-serif">Panamá, PTY</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Misión & Visión section -->
  <section id="qs-mision" style="padding: 6rem 0; border-top: 1px solid rgba(0,0,0,0.06); background:#F8F9FA">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

      <div style="text-align:center;margin-bottom:4rem">
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:0.875rem;font-family:'DM Sans',sans-serif">
          Nuestro Propósito
        </p>
        <h2 style="font-family:'Lexend',sans-serif;font-weight:900;color:#1f2937;font-size:clamp(1.875rem,3vw,2.5rem);letter-spacing:-0.02em">
          Misión & Visión
        </h2>
      </div>

      <div id="mv-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:2.5rem">

        <!-- Misión -->
        <div style="background:#FFFFFF;border:1px solid rgba(0,0,0,0.08);border-radius:20px;padding:2.5rem;box-shadow:0 2px 16px rgba(0,0,0,0.05)">
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
            <div style="width:3px;height:3rem;background:linear-gradient(180deg,#FD9800,rgba(253,152,0,0.2));border-radius:2px;flex-shrink:0"></div>
            <div>
              <span style="font-size:0.6875rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(253,152,0,0.7);font-family:'DM Sans',sans-serif">01</span>
              <h3 style="font-family:'Lexend',sans-serif;font-weight:800;font-size:1.375rem;color:#1f2937;line-height:1.2;margin-top:0.2rem">Misión</h3>
            </div>
          </div>
          <div style="width:100%;height:1px;background:rgba(0,0,0,0.06);margin-bottom:1.5rem"></div>
          <p style="font-size:0.9375rem;line-height:1.8;color:rgba(69,79,94,0.8);font-family:'DM Sans',sans-serif">
            Ofrecer soluciones en acústica arquitectónica que mejoren la calidad de vida y la experiencia de las personas en sus espacios, a través de un diseño sonoro eficiente, innovador y sostenible. Nos enfocamos en crear ambientes confortables, funcionales y con un sonido equilibrado, adaptados a las necesidades de cada cliente.
          </p>
        </div>

        <!-- Visión -->
        <div style="background:#FFFFFF;border:1px solid rgba(0,0,0,0.08);border-radius:20px;padding:2.5rem;box-shadow:0 2px 16px rgba(0,0,0,0.05)">
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
            <div style="width:3px;height:3rem;background:linear-gradient(180deg,#FD9800,rgba(253,152,0,0.2));border-radius:2px;flex-shrink:0"></div>
            <div>
              <span style="font-size:0.6875rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(253,152,0,0.7);font-family:'DM Sans',sans-serif">02</span>
              <h3 style="font-family:'Lexend',sans-serif;font-weight:800;font-size:1.375rem;color:#1f2937;line-height:1.2;margin-top:0.2rem">Visión</h3>
            </div>
          </div>
          <div style="width:100%;height:1px;background:rgba(0,0,0,0.06);margin-bottom:1.5rem"></div>
          <p style="font-size:0.9375rem;line-height:1.8;color:rgba(69,79,94,0.8);font-family:'DM Sans',sans-serif">
            Ser la empresa líder en soluciones de acústica arquitectónica en la región, reconocida por transformar espacios en lugares donde el sonido se vive con claridad, armonía y confort, contribuyendo al bienestar de las personas y al desarrollo sostenible de la sociedad sin dejar a un lado la estética.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Valores section -->
  <section id="qs-valores" style="padding: 6rem 0; border-top: 1px solid rgba(0,0,0,0.06)">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

      <div style="text-align:center;margin-bottom:4rem">
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:0.875rem;font-family:'DM Sans',sans-serif">
          Nuestros Valores
        </p>
        <h2 style="font-family:'Lexend',sans-serif;font-weight:900;color:#1f2937;font-size:clamp(1.875rem,3vw,2.5rem);letter-spacing:-0.02em">
          Lo que nos define
        </h2>
      </div>

      <div id="valores-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem">
        {valores.map(v => (
          <div
            class="valor-card"
            style="position:relative;background:#FFFFFF;border:1px solid rgba(0,0,0,0.08);border-radius:20px;padding:2.5rem 2rem;text-align:center;transition:border-color 0.3s,transform 0.35s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.3s;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.05)"
            onmouseenter="this.style.borderColor='rgba(253,152,0,0.35)';this.style.transform='translateY(-8px)';this.style.boxShadow='0 24px 48px rgba(0,0,0,0.1),0 0 0 1px rgba(253,152,0,0.08)'"
            onmouseleave="this.style.borderColor='rgba(0,0,0,0.08)';this.style.transform='translateY(0)';this.style.boxShadow='0 2px 16px rgba(0,0,0,0.05)'"
          >
            <!-- Número decorativo de fondo -->
            <div style="position:absolute;top:-0.5rem;right:1rem;font-family:'Lexend',sans-serif;font-weight:900;font-size:5rem;color:rgba(253,152,0,0.05);line-height:1;pointer-events:none;user-select:none">
              {v.numero}
            </div>

            <!-- Accent line centrada -->
            <div style="width:2.5rem;height:2px;background:#FD9800;border-radius:2px;margin:0 auto 1.5rem"></div>

            <h3 style="font-family:'Lexend',sans-serif;font-weight:800;font-size:1.25rem;color:#1f2937;margin-bottom:1rem;line-height:1.2">
              {v.titulo}
            </h3>
            <p style="font-size:0.9375rem;line-height:1.7;color:rgba(69,79,94,0.7);font-family:'DM Sans',sans-serif">
              {v.descripcion}
            </p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <CTABanner />
</Layout>

<style>
  @media (max-width: 1023px) {
    #historia-grid { grid-template-columns: 1fr !important; }
    #valores-grid { grid-template-columns: repeat(2, 1fr) !important; }
    #mv-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 767px) {
    #valores-grid { grid-template-columns: 1fr !important; }
    #historia-grid { gap: 2rem !important; }
    /* Reducir padding vertical en todas las secciones */
    #qs-historia { padding: 3.5rem 0 !important; }
    #qs-mision   { padding: 3.5rem 0 !important; }
    #qs-valores  { padding: 3.5rem 0 !important; }
    /* Reducir imagen de equipo en mobile */
    #historia-grid img { height: 18rem !important; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);
  gsap.from('.valor-card', {
    y: 40, opacity: 0, stagger: 0.15, duration: 0.7, ease: 'power2.out',
    scrollTrigger: { trigger: '.valor-card', start: 'top 85%' }
  });
</script>
