---
interface Props {
  titulo: string;
  subtitulo?: string;
  imagen?: string;
  breadcrumb?: string;
}
import { b } from '../utils/base';
const { titulo, subtitulo, imagen, breadcrumb } = Astro.props;
const imagenSrc = imagen ?? `${b}/images/Studio3.webp`;
---
<section class="hero-interno" style={`position:relative;display:flex;align-items:flex-end;height:60vh;min-height:400px;max-height:640px;background-image:url('${imagenSrc}');background-size:cover;background-position:center;background-attachment:fixed`}>

  <!-- Overlay + accent line -->
  <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,1) 0%,rgba(8,8,8,0.75) 40%,rgba(8,8,8,0.35) 80%,rgba(8,8,8,0.2) 100%)"></div>
  <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent 0%,rgba(253,152,0,0.4) 30%,rgba(253,152,0,0.4) 70%,transparent 100%)"></div>

  <!-- Content positioned in bottom third -->
  <div style="position:relative;z-index:10;width:100%;padding-bottom:3.5rem">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

      <!-- Breadcrumb -->
      {breadcrumb && (
        <p style="font-size:0.75rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;font-family:'DM Sans',sans-serif">
          <a href={`${b}/`} style="color:rgba(255,255,255,0.4);transition:color 0.2s" onmouseenter="this.style.color='rgba(253,152,0,0.7)'" onmouseleave="this.style.color='rgba(255,255,255,0.4)'">Inicio</a>
          <span style="color:rgba(255,255,255,0.2)">›</span>
          <span style="color:rgba(253,152,0,0.7)">{breadcrumb}</span>
        </p>
      )}

      <!-- Accent line -->
      <div style="width:2.5rem;height:2px;background:linear-gradient(90deg,#FD9800 0%,rgba(253,152,0,0.3) 100%);border-radius:2px;margin-bottom:1.25rem"></div>

      <!-- Title -->
      <h1 style="font-family:'Lexend',sans-serif;font-weight:900;color:white;line-height:1.05;font-size:clamp(2.25rem,5vw,3.75rem);letter-spacing:-0.02em;margin-bottom:{subtitulo ? '1rem' : '0'}">
        {titulo}
      </h1>

      <!-- Subtitle -->
      {subtitulo && (
        <p style="font-size:clamp(1rem,2vw,1.25rem);color:rgba(255,255,255,0.6);max-width:36rem;line-height:1.6;margin-top:1rem;font-family:'DM Sans',sans-serif">
          {subtitulo}
        </p>
      )}

    </div>
  </div>

</section>

<style>
  @supports (-webkit-overflow-scrolling: touch) {
    .hero-interno { background-attachment: scroll !important; }
  }
  @media (max-width: 767px) {
    .hero-interno { background-attachment: scroll !important; }
  }
</style>

<script>
  import gsap from 'gsap';
  const heroEl = document.querySelector('.hero-interno');
  if (heroEl) {
    gsap.from(heroEl.querySelectorAll('h1, p'), {
      y: 20,
      opacity: 0,
      duration: 0.8,
      stagger: 0.12,
      ease: 'power3.out',
      delay: 0.1,
    });
  }
</script>
