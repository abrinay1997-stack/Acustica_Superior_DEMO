---
import { b } from '../utils/base';
const links = [
  { href: `${b}/`, label: 'Inicio' },
  { href: `${b}/quienes-somos`, label: 'Quiénes Somos' },
  { href: `${b}/servicios`, label: 'Servicios' },
  { href: `${b}/proyectos`, label: 'Proyectos' },
  { href: `${b}/contacto`, label: 'Contacto' },
];
---
<header
  id="navbar"
  style="position:fixed;top:0;left:0;right:0;z-index:100;transition:background 0.4s ease,backdrop-filter 0.4s ease,border-color 0.4s ease,box-shadow 0.4s ease;background:transparent;border-bottom:1px solid transparent"
>
  <nav style="max-width:80rem;margin:0 auto;padding:0 1.5rem;height:7rem;display:flex;align-items:center;justify-content:space-between">

    <!-- Logo -->
    <a href={`${b}/`} style="display:flex;align-items:center;flex-shrink:0">
      <img src={`${b}/Logo/LOGO.webp`} alt="Acústica Superior" style="height:8rem;width:auto" />
    </a>

    <!-- Desktop nav -->
    <ul id="desktop-nav" style="display:flex;align-items:center;gap:2rem;list-style:none;margin:0;padding:0">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="nav-link"
            style="font-size:0.875rem;font-weight:500;color:rgba(255,255,255,0.85);transition:color 0.2s;position:relative;padding-bottom:2px;display:inline-block;font-family:'DM Sans',sans-serif"
          >
            {link.label}
            <span
              style="position:absolute;bottom:-1px;left:0;width:0;height:1.5px;background:#FD9800;transition:width 0.3s ease;border-radius:1px"
              class="nav-underline"
            ></span>
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA button -->
    <a
      href="https://wa.me/50761399247"
      target="_blank"
      rel="noopener"
      id="nav-cta"
      style="display:none;align-items:center;gap:0.5rem;font-size:0.8125rem;font-weight:700;color:#FFFFFF;background:#FD9800;padding:0.625rem 1.375rem;border-radius:6px;transition:filter 0.2s,transform 0.2s,box-shadow 0.2s;white-space:nowrap;box-shadow:0 4px 16px rgba(253,152,0,0.3);font-family:'Lexend',sans-serif"
      onmouseenter="this.style.filter='brightness(1.08)';this.style.transform='translateY(-1px)';this.style.boxShadow='0 8px 24px rgba(253,152,0,0.45)'"
      onmouseleave="this.style.filter='brightness(1)';this.style.transform='translateY(0)';this.style.boxShadow='0 4px 16px rgba(253,152,0,0.3)'"
    >
      Cotizar
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      aria-label="Abrir menú"
      style="display:none;flex-direction:column;gap:5px;padding:0.5rem;background:none;border:none;cursor:pointer"
    >
      <span style="width:22px;height:1.5px;background:white;display:block;border-radius:2px;transition:transform 0.3s,opacity 0.3s,background 0.4s" id="bar1" class="hamburger-bar"></span>
      <span style="width:22px;height:1.5px;background:white;display:block;border-radius:2px;transition:opacity 0.3s,background 0.4s" id="bar2" class="hamburger-bar"></span>
      <span style="width:22px;height:1.5px;background:white;display:block;border-radius:2px;transition:transform 0.3s,opacity 0.3s,background 0.4s" id="bar3" class="hamburger-bar"></span>
    </button>

  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    style="display:none;margin:0 1rem 1rem;padding:1.5rem;background:#FFFFFF;border:1px solid rgba(0,0,0,0.1);box-shadow:0 8px 32px rgba(0,0,0,0.12);border-radius:16px"
  >
    <ul style="display:flex;flex-direction:column;gap:1rem;list-style:none;margin:0;padding:0">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            style="font-size:1rem;font-weight:500;color:rgb(69,79,94);display:block;padding:0.375rem 0;transition:color 0.2s;font-family:'DM Sans',sans-serif"
            onmouseenter="this.style.color='#FD9800'"
            onmouseleave="this.style.color='rgb(69,79,94)'"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li style="margin-top:0.5rem;padding-top:1rem;border-top:1px solid rgba(0,0,0,0.08)">
        <a
          href="https://wa.me/50761399247"
          target="_blank"
          rel="noopener"
          style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.875rem;font-weight:700;color:#FFFFFF;background:#FD9800;padding:0.75rem 1.5rem;border-radius:6px;font-family:'Lexend',sans-serif"
        >
          Cotizar por WhatsApp →
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const navLinks = document.querySelectorAll('.nav-link') as NodeListOf<HTMLElement>;
  const hamburgerBars = document.querySelectorAll('.hamburger-bar') as NodeListOf<HTMLElement>;

  let isScrolled = false;

  const updateNavbar = () => {
    const scrolled = window.scrollY > 80;
    if (scrolled === isScrolled) return;
    isScrolled = scrolled;

    if (scrolled) {
      navbar.style.background = 'rgba(255,255,255,0.97)';
      navbar.style.backdropFilter = 'blur(20px)';
      (navbar.style as any).webkitBackdropFilter = 'blur(20px)';
      navbar.style.borderBottomColor = 'rgba(0,0,0,0.08)';
      navbar.style.boxShadow = '0 2px 20px rgba(0,0,0,0.08)';
      navLinks.forEach(a => { a.style.color = 'rgb(69,79,94)'; });
      hamburgerBars.forEach(bar => { (bar as HTMLElement).style.background = 'rgb(69,79,94)'; });
    } else {
      navbar.style.background = 'transparent';
      navbar.style.backdropFilter = 'none';
      (navbar.style as any).webkitBackdropFilter = 'none';
      navbar.style.borderBottomColor = 'transparent';
      navbar.style.boxShadow = 'none';
      navLinks.forEach(a => { a.style.color = 'rgba(255,255,255,0.85)'; });
      hamburgerBars.forEach(bar => { (bar as HTMLElement).style.background = 'white'; });
    }
  };
  window.addEventListener('scroll', updateNavbar, { passive: true });

  // Nav underline hover
  document.querySelectorAll('#desktop-nav a').forEach(a => {
    const underline = a.querySelector('.nav-underline') as HTMLElement | null;
    if (underline) {
      a.addEventListener('mouseenter', () => { underline.style.width = '100%'; });
      a.addEventListener('mouseleave', () => { underline.style.width = '0'; });
    }
  });

  // Responsive: show/hide elements
  const applyResponsive = () => {
    const desktopNav = document.getElementById('desktop-nav')!;
    const navCta = document.getElementById('nav-cta')!;
    const menuToggle = document.getElementById('menu-toggle')!;
    const isDesktop = window.innerWidth >= 768;
    desktopNav.style.display = isDesktop ? 'flex' : 'none';
    navCta.style.display = isDesktop ? 'flex' : 'none';
    menuToggle.style.display = isDesktop ? 'none' : 'flex';
  };
  applyResponsive();
  window.addEventListener('resize', applyResponsive);

  // Mobile toggle
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  let menuOpen = false;
  toggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu.style.display = menuOpen ? 'block' : 'none';
    bar1.style.transform = menuOpen ? 'rotate(45deg) translate(5px, 5px)' : '';
    bar2.style.opacity = menuOpen ? '0' : '1';
    bar3.style.transform = menuOpen ? 'rotate(-45deg) translate(5px, -5px)' : '';
  });
</script>
