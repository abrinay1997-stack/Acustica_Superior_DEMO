---
import { b } from '../utils/base';
---
<section style="padding: 6rem 0; position: relative; overflow: hidden">

  <!-- Background Studio image (dark section like old site) -->
  <div style="position:absolute;inset:0">
    <img
      src={`${b}/images/Studio4.webp`}
      alt=""
      style="width:100%;height:100%;object-fit:cover;display:block"
      loading="lazy"
    />
    <div style="position:absolute;inset:0;background:rgba(8,8,8,0.78)"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(8,8,8,0.3) 0%,rgba(8,8,8,0.55) 100%)"></div>
  </div>

  <div style="position:relative;z-index:10;max-width:48rem;margin:0 auto;padding:0 1.5rem;text-align:center">

    <div style="display:inline-flex;align-items:center;gap:0.5rem;font-size:0.75rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:#FD9800;margin-bottom:1.5rem;padding:0.375rem 1rem;border-radius:999px;border:1px solid rgba(253,152,0,0.3);background:rgba(253,152,0,0.08);font-family:'DM Sans',sans-serif">
      ¿Listo para transformar tu espacio?
    </div>

    <h2 style="font-family:'Lexend',sans-serif;font-weight:800;color:white;line-height:1.1;margin-bottom:1.25rem;font-size:clamp(2.25rem,4vw,3.25rem)">
      El sonido perfecto está<br>
      <span style="background:linear-gradient(135deg,#FD9800 0%,#FFAD33 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">
        a un mensaje de distancia.
      </span>
    </h2>

    <p style="font-size:1.125rem;color:rgba(255,255,255,0.65);margin-bottom:2.5rem;line-height:1.7;font-family:'DM Sans',sans-serif">
      Para servicios especializados contáctanos hoy.
    </p>

    <a
      href="https://wa.me/50761399247?text=Hola,%20me%20gustaría%20solicitar%20una%20cotización"
      target="_blank"
      rel="noopener"
      class="btn-primary"
      style="font-size:1.0625rem;padding:1rem 2.5rem;border-radius:8px;text-decoration:none"
    >
      Cotiza Con Nosotros →
    </a>

  </div>
</section>
