---
interface Props {
  preview?: boolean;
}
const { preview = false } = Astro.props;
import { b } from '../utils/base';

const servicios = [
  {
    imagen: `${b}/images/Adecuación_acustica.webp`,
    titulo: 'Adecuación Acústica',
    descripcion: 'Optimizamos el comportamiento sonoro de tu espacio interior mediante análisis y tratamiento personalizado.',
    id: 'adecuacion',
    numero: '01',
  },
  {
    imagen: `${b}/images/Aislamiento_y_bloqueo_acustico.webp`,
    titulo: 'Aislamiento y Bloqueo Acústico',
    descripcion: 'Barreras técnicas que controlan la transmisión de sonido entre ambientes para máxima privacidad.',
    id: 'aislamiento',
    numero: '02',
  },
  {
    imagen: `${b}/images/Balance_frecuencial.webp`,
    titulo: 'Balance Frecuencial',
    descripcion: 'Corrección de frecuencias para lograr una respuesta plana y fiel en estudios de grabación y mezcla.',
    id: 'balance',
    numero: '03',
  },
  {
    imagen: `${b}/images/Control_de_Ruido_Industrial.webp`,
    titulo: 'Control de Ruido Industrial',
    descripcion: 'Soluciones de ingeniería acústica para entornos industriales, cumpliendo normativas de seguridad laboral.',
    id: 'ruido',
    numero: '04',
  },
  {
    imagen: `${b}/images/Medición_y_diseño_acústico.webp`,
    titulo: 'Medición y Diseño Acústico',
    descripcion: 'Diagnóstico profesional con equipos de medición calibrados y diseño de soluciones a medida.',
    id: 'medicion',
    numero: '05',
  },
  {
    imagen: `${b}/images/hero-servicios.webp`,
    titulo: 'Diseño Acústico Personalizado',
    descripcion: 'Co-creamos contigo el tratamiento ideal: escuchamos tus ideas y las transformamos en una solución concreta, funcional y visualmente impresionante.',
    id: 'diseno',
    numero: '06',
  },
];

const items = preview ? servicios.slice(0, 3) : servicios;
const firstRow = items.slice(0, 3);
const secondRow = preview ? [] : items.slice(3);
---

<div id="servicios-grid" style="max-width:80rem;margin:0 auto;padding:0 1.5rem">

  <!-- Fila 1: 3 cards -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;align-items:stretch">
    {firstRow.map((s) => (
      <a
        href={`${b}/servicios#${s.id}`}
        class="service-card"
        style="position:relative;display:flex;flex-direction:column;height:100%;overflow:hidden;border-radius:20px;border:1px solid rgba(0,0,0,0.08);background:#FFFFFF;box-shadow:0 2px 16px rgba(0,0,0,0.06);transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),border-color 0.3s,box-shadow 0.3s;text-decoration:none"
        onmouseenter="this.style.borderColor='rgba(253,152,0,0.35)';this.style.transform='translateY(-8px)';this.style.boxShadow='0 20px 48px rgba(0,0,0,0.12),0 0 0 1px rgba(253,152,0,0.1)'"
        onmouseleave="this.style.borderColor='rgba(0,0,0,0.08)';this.style.transform='translateY(0)';this.style.boxShadow='0 2px 16px rgba(0,0,0,0.06)'"
      >
        <!-- Imagen -->
        <div style="position:relative;overflow:hidden;height:13rem;flex-shrink:0">
          <img
            src={s.imagen}
            alt={s.titulo}
            style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;display:block"
            loading="lazy"
            onmouseenter="this.style.transform='scale(1.06)'"
            onmouseleave="this.style.transform='scale(1)'"
          />
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.45) 0%,transparent 55%)"></div>
          <div style="position:absolute;top:0.875rem;right:0.875rem;font-family:'Lexend',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.12em;color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.35);backdrop-filter:blur(8px);padding:0.25rem 0.5rem;border-radius:4px">
            {s.numero}
          </div>
        </div>

        <!-- Body -->
        <div style="padding:1.5rem 1.5rem 0;flex:1;display:flex;flex-direction:column;gap:0.5rem">
          <div style="width:2rem;height:2px;background:#FD9800;border-radius:2px;flex-shrink:0"></div>
          <h3 style="font-family:'Lexend',sans-serif;font-weight:700;font-size:1.1rem;color:#1f2937;line-height:1.3">
            {s.titulo}
          </h3>
          <p style="font-size:0.875rem;line-height:1.65;color:rgba(69,79,94,0.7);font-family:'DM Sans',sans-serif">
            {s.descripcion}
          </p>
        </div>

        <!-- Footer -->
        <div style="padding:1rem 1.5rem 1.5rem">
          <div style="font-size:0.8125rem;font-weight:600;color:#FD9800;display:inline-flex;align-items:center;gap:0.375rem;font-family:'DM Sans',sans-serif">
            Ver más <span style="transition:transform 0.2s">→</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <!-- Fila 2: siguientes 3 cards (solo vista completa) -->
  {secondRow.length > 0 && (
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:1.5rem;align-items:stretch">
      {secondRow.map((s) => (
        <a
          href={`${b}/servicios#${s.id}`}
          class="service-card"
          style="position:relative;display:flex;flex-direction:column;height:100%;overflow:hidden;border-radius:20px;border:1px solid rgba(0,0,0,0.08);background:#FFFFFF;box-shadow:0 2px 16px rgba(0,0,0,0.06);transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),border-color 0.3s,box-shadow 0.3s;text-decoration:none"
          onmouseenter="this.style.borderColor='rgba(253,152,0,0.35)';this.style.transform='translateY(-8px)';this.style.boxShadow='0 20px 48px rgba(0,0,0,0.12),0 0 0 1px rgba(253,152,0,0.1)'"
          onmouseleave="this.style.borderColor='rgba(0,0,0,0.08)';this.style.transform='translateY(0)';this.style.boxShadow='0 2px 16px rgba(0,0,0,0.06)'"
        >
          <!-- Imagen -->
          <div style="position:relative;overflow:hidden;height:13rem;flex-shrink:0">
            <img
              src={s.imagen}
              alt={s.titulo}
              style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;display:block"
              loading="lazy"
              onmouseenter="this.style.transform='scale(1.06)'"
              onmouseleave="this.style.transform='scale(1)'"
            />
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.45) 0%,transparent 55%)"></div>
            <div style="position:absolute;top:0.875rem;right:0.875rem;font-family:'Lexend',sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.12em;color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.35);backdrop-filter:blur(8px);padding:0.25rem 0.5rem;border-radius:4px">
              {s.numero}
            </div>
          </div>

          <!-- Body -->
          <div style="padding:1.5rem 1.5rem 0;flex:1;display:flex;flex-direction:column;gap:0.5rem">
            <div style="width:2rem;height:2px;background:#FD9800;border-radius:2px;flex-shrink:0"></div>
            <h3 style="font-family:'Lexend',sans-serif;font-weight:700;font-size:1.1rem;color:#1f2937;line-height:1.3">
              {s.titulo}
            </h3>
            <p style="font-size:0.875rem;line-height:1.65;color:rgba(69,79,94,0.7);font-family:'DM Sans',sans-serif">
              {s.descripcion}
            </p>
          </div>

          <!-- Footer -->
          <div style="padding:1rem 1.5rem 1.5rem">
            <div style="font-size:0.8125rem;font-weight:600;color:#FD9800;display:inline-flex;align-items:center;gap:0.375rem;font-family:'DM Sans',sans-serif">
              Ver más <span>→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}

</div>

<style>
  @media (max-width: 767px) {
    #servicios-grid > div {
      grid-template-columns: 1fr !important;
    }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    #servicios-grid > div {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.service-card', {
    y: 40,
    opacity: 0,
    stagger: 0.1,
    duration: 0.7,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '#servicios-grid',
      start: 'top 85%',
    },
  });
</script>
