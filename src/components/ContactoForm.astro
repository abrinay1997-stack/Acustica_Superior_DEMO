---
---
<form
  name="contacto"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-6"
>
  <input type="hidden" name="form-name" value="contacto" />
  <p class="hidden"><label>No llenar: <input name="bot-field" /></label></p>

  <div>
    <label for="nombre" class="block text-sm font-medium mb-2" style="color: rgba(255,255,255,0.45)">Nombre completo *</label>
    <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre"
      class="w-full glass px-4 py-3 text-white outline-none transition-colors"
      style="placeholder-color: rgba(255,255,255,0.3)" />
  </div>

  <div>
    <label for="email" class="block text-sm font-medium mb-2" style="color: rgba(255,255,255,0.45)">Correo electrónico *</label>
    <input type="email" id="email" name="email" required placeholder="tucorreo@email.com"
      class="w-full glass px-4 py-3 text-white outline-none transition-colors" />
  </div>

  <div>
    <label for="mensaje" class="block text-sm font-medium mb-2" style="color: rgba(255,255,255,0.45)">Mensaje *</label>
    <textarea id="mensaje" name="mensaje" required rows="5" placeholder="Cuéntanos sobre tu proyecto..."
      class="w-full glass px-4 py-3 text-white outline-none transition-colors resize-none"></textarea>
  </div>

  <button type="submit" class="w-full font-bold py-4 rounded hover:brightness-110 transition-all text-lg text-black" style="background: #FDE817">
    Enviar Mensaje
  </button>
</form>
