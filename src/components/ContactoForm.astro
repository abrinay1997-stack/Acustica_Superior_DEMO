---
---
<form
  name="contacto"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  style="display:flex;flex-direction:column;gap:1.5rem"
>
  <input type="hidden" name="form-name" value="contacto" />
  <p style="display:none"><label>No llenar: <input name="bot-field" /></label></p>

  <div>
    <label for="nombre" style="display:block;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;color:rgba(69,79,94,0.7);margin-bottom:0.5rem;font-family:'DM Sans',sans-serif">
      Nombre completo <span style="color:#FD9800">*</span>
    </label>
    <input
      type="text"
      id="nombre"
      name="nombre"
      required
      placeholder="Tu nombre completo"
      class="form-input"
      style="width:100%;background:#FFFFFF;border:1px solid rgba(0,0,0,0.12);border-radius:8px;padding:0.875rem 1rem;color:#1f2937;font-size:0.9375rem;outline:none;transition:border-color 0.2s,box-shadow 0.2s;font-family:'DM Sans',sans-serif"
    />
  </div>

  <div>
    <label for="email" style="display:block;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;color:rgba(69,79,94,0.7);margin-bottom:0.5rem;font-family:'DM Sans',sans-serif">
      Correo electrónico <span style="color:#FD9800">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder="tucorreo@email.com"
      class="form-input"
      style="width:100%;background:#FFFFFF;border:1px solid rgba(0,0,0,0.12);border-radius:8px;padding:0.875rem 1rem;color:#1f2937;font-size:0.9375rem;outline:none;transition:border-color 0.2s,box-shadow 0.2s;font-family:'DM Sans',sans-serif"
    />
  </div>

  <div>
    <label for="telefono" style="display:block;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;color:rgba(69,79,94,0.7);margin-bottom:0.5rem;font-family:'DM Sans',sans-serif">
      Teléfono <span style="color:rgba(69,79,94,0.35);font-weight:400">(opcional)</span>
    </label>
    <input
      type="tel"
      id="telefono"
      name="telefono"
      placeholder="+507 0000 0000"
      class="form-input"
      style="width:100%;background:#FFFFFF;border:1px solid rgba(0,0,0,0.12);border-radius:8px;padding:0.875rem 1rem;color:#1f2937;font-size:0.9375rem;outline:none;transition:border-color 0.2s,box-shadow 0.2s;font-family:'DM Sans',sans-serif"
    />
  </div>

  <div>
    <label for="mensaje" style="display:block;font-size:0.8125rem;font-weight:600;letter-spacing:0.04em;color:rgba(69,79,94,0.7);margin-bottom:0.5rem;font-family:'DM Sans',sans-serif">
      Mensaje <span style="color:#FD9800">*</span>
    </label>
    <textarea
      id="mensaje"
      name="mensaje"
      required
      rows="5"
      placeholder="Cuéntanos sobre tu proyecto: tipo de espacio, dimensiones, objetivo acústico..."
      class="form-input"
      style="width:100%;background:#FFFFFF;border:1px solid rgba(0,0,0,0.12);border-radius:8px;padding:0.875rem 1rem;color:#1f2937;font-size:0.9375rem;outline:none;transition:border-color 0.2s,box-shadow 0.2s;resize:vertical;min-height:8rem;font-family:'DM Sans',sans-serif;line-height:1.6"
    ></textarea>
  </div>

  <button
    type="submit"
    style="width:100%;background:#FD9800;color:#FFFFFF;font-weight:700;font-size:1rem;padding:1rem 1.5rem;border-radius:8px;border:none;cursor:pointer;transition:filter 0.2s,transform 0.2s,box-shadow 0.2s;font-family:'Lexend',sans-serif;letter-spacing:0.01em;box-shadow:0 4px 24px rgba(253,152,0,0.3)"
    onmouseenter="this.style.filter='brightness(1.08)';this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 32px rgba(253,152,0,0.45)'"
    onmouseleave="this.style.filter='brightness(1)';this.style.transform='translateY(0)';this.style.boxShadow='0 4px 24px rgba(253,152,0,0.3)'"
  >
    Enviar Mensaje →
  </button>

</form>

<style>
  .form-input::placeholder {
    color: rgba(69, 79, 94, 0.35);
  }
  .form-input:focus {
    border-color: rgba(253, 152, 0, 0.55) !important;
    box-shadow: 0 0 0 3px rgba(253, 152, 0, 0.1) !important;
    background: #FFFDF8 !important;
  }
  .form-input:hover {
    border-color: rgba(0, 0, 0, 0.2) !important;
  }
</style>
