---
import { b } from '../utils/base';
---
<footer style="background:#111111;border-top:1px solid rgba(255,255,255,0.06);position:relative;overflow:hidden">

  <div style="max-width:80rem;margin:0 auto;padding:4rem 1.5rem">
    <div id="footer-grid" style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:3rem;align-items:start">

      <!-- Brand col -->
      <div>
        <a href={`${b}/`}>
          <img src={`${b}/Logo/LOGO.webp`} alt="Acústica Superior" style="height:5.6rem;width:auto;margin-bottom:1.25rem" />
        </a>
        <p style="color:rgba(255,255,255,0.45);font-size:0.9375rem;line-height:1.75;max-width:22rem;font-family:'DM Sans',sans-serif">
          Soluciones acústicas profesionales para estudios, oficinas y espacios industriales en Panamá. Precisión técnica con estética superior.
        </p>
        <!-- Social links con SVG icons -->
        <div style="display:flex;gap:0.75rem;margin-top:1.75rem">
          <a href="https://www.instagram.com/acusticasuperior/" target="_blank" rel="noopener"
            style="width:2.5rem;height:2.5rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.5);transition:all 0.2s"
            onmouseenter="this.style.borderColor='#E1306C';this.style.color='#E1306C';this.style.background='rgba(225,48,108,0.1)'"
            onmouseleave="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.5)';this.style.background='rgba(255,255,255,0.05)'">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:1.0625rem;height:1.0625rem">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://www.facebook.com/acusticasuperior" target="_blank" rel="noopener"
            style="width:2.5rem;height:2.5rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.5);transition:all 0.2s"
            onmouseenter="this.style.borderColor='#1877F2';this.style.color='#1877F2';this.style.background='rgba(24,119,242,0.1)'"
            onmouseleave="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.5)';this.style.background='rgba(255,255,255,0.05)'">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:1.0625rem;height:1.0625rem">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://wa.me/50761399247" target="_blank" rel="noopener"
            style="width:2.5rem;height:2.5rem;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.5);transition:all 0.2s"
            onmouseenter="this.style.borderColor='#25D366';this.style.color='#25D366';this.style.background='rgba(37,211,102,0.1)'"
            onmouseleave="this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.5)';this.style.background='rgba(255,255,255,0.05)'">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:1.0625rem;height:1.0625rem">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav col -->
      <div>
        <h4 style="color:rgba(255,255,255,0.9);font-family:'Lexend',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:1.25rem">
          Páginas
        </h4>
        <ul style="display:flex;flex-direction:column;gap:0.75rem;list-style:none;padding:0;margin:0">
          {[
            { href: `${b}/quienes-somos`, label: 'Quiénes Somos' },
            { href: `${b}/servicios`, label: 'Servicios' },
            { href: `${b}/proyectos`, label: 'Proyectos' },
            { href: `${b}/contacto`, label: 'Contacto' },
          ].map(link => (
            <li>
              <a href={link.href} style="color:rgba(255,255,255,0.45);font-size:0.9375rem;transition:color 0.2s;font-family:'DM Sans',sans-serif"
                onmouseenter="this.style.color='#FD9800'"
                onmouseleave="this.style.color='rgba(255,255,255,0.45)'">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact col -->
      <div>
        <h4 style="color:rgba(255,255,255,0.9);font-family:'Lexend',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:1.25rem">
          Contacto
        </h4>
        <ul style="display:flex;flex-direction:column;gap:0.875rem;list-style:none;padding:0;margin:0">
          <li>
            <a href="https://wa.me/50761399247" target="_blank" rel="noopener"
              style="color:rgba(255,255,255,0.45);font-size:0.9375rem;display:flex;align-items:center;gap:0.5rem;transition:color 0.2s;font-family:'DM Sans',sans-serif"
              onmouseenter="this.style.color='#25D366'" onmouseleave="this.style.color='rgba(255,255,255,0.45)'">
              <span style="color:#25D366;font-size:0.9rem">●</span> +507 6139 9247
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/acusticasuperior/" target="_blank" rel="noopener"
              style="color:rgba(255,255,255,0.45);font-size:0.9375rem;display:flex;align-items:center;gap:0.5rem;transition:color 0.2s;font-family:'DM Sans',sans-serif"
              onmouseenter="this.style.color='white'" onmouseleave="this.style.color='rgba(255,255,255,0.45)'">
              <span style="color:rgba(255,255,255,0.25);font-size:1rem">@</span> acusticasuperior
            </a>
          </li>
          <li style="color:rgba(255,255,255,0.45);font-size:0.9375rem;display:flex;align-items:center;gap:0.5rem;font-family:'DM Sans',sans-serif">
            <span style="color:rgba(253,152,0,0.7);font-size:0.875rem">◆</span> Panamá, PTY
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div style="margin-top:3rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem">
      <p style="color:rgba(255,255,255,0.25);font-size:0.8125rem;font-family:'DM Sans',sans-serif">
        © {new Date().getFullYear()} Acústica Superior. Todos los derechos reservados.
      </p>
      <!-- Legal links -->
      <div style="display:flex;gap:1.25rem;align-items:center;flex-wrap:wrap">
        <a href={`${b}/politica-de-privacidad`}
          style="color:rgba(255,255,255,0.25);font-size:0.8125rem;font-family:'DM Sans',sans-serif;transition:color 0.2s;text-decoration:none"
          onmouseenter="this.style.color='rgba(253,152,0,0.7)'"
          onmouseleave="this.style.color='rgba(255,255,255,0.25)'">
          Política de Privacidad
        </a>
        <span style="color:rgba(255,255,255,0.12);font-size:0.75rem">·</span>
        <a href={`${b}/terminos-de-uso`}
          style="color:rgba(255,255,255,0.25);font-size:0.8125rem;font-family:'DM Sans',sans-serif;transition:color 0.2s;text-decoration:none"
          onmouseenter="this.style.color='rgba(253,152,0,0.7)'"
          onmouseleave="this.style.color='rgba(255,255,255,0.25)'">
          Términos de Uso
        </a>
        <span style="color:rgba(255,255,255,0.12);font-size:0.75rem">·</span>
        <span style="color:rgba(255,255,255,0.18);font-size:0.8125rem;font-family:'DM Sans',sans-serif">
          Panamá, República de Panamá
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  @media (max-width: 767px) {
    #footer-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
  }
</style>
