---
import Lightbox from './Lightbox.astro';

import { b } from '../utils/base';
const proyectos = Array.from({ length: 12 }, (_, i) => ({
  src: `${b}/images/Studio${i + 1}.webp`,
  alt: `Studio ${i + 1} — Proyecto acústico Acústica Superior`,
  label: `Studio ${i + 1}`,
}));
---
<Lightbox />

<section style="padding:2rem 0 5rem">
  <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">
    <div id="masonry-grid" style="columns:3;column-gap:1rem">
      {proyectos.map((p, i) => (
        <button
          class="proyecto-item"
          style="position:relative;width:100%;margin-bottom:1rem;display:block;overflow:hidden;border-radius:16px;border:1px solid rgba(255,255,255,0.08);cursor:pointer;background:none;padding:0;break-inside:avoid;transition:border-color 0.3s,transform 0.3s"
          data-index={i}
          aria-label={`Ver ${p.label}`}
          onmouseenter="this.style.borderColor='rgba(253,232,23,0.3)';this.style.transform='scale(1.02)';this.querySelector('.proyecto-overlay').style.opacity='1';this.querySelector('img').style.transform='scale(1.06)'"
          onmouseleave="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='scale(1)';this.querySelector('.proyecto-overlay').style.opacity='0';this.querySelector('img').style.transform='scale(1)'"
        >
          <img
            src={p.src}
            alt={p.alt}
            style="width:100%;display:block;object-fit:cover;transition:transform 0.5s ease"
            loading="lazy"
          />
          <div
            class="proyecto-overlay"
            style="position:absolute;inset:0;background:rgba(8,8,8,0.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.3s"
          >
            <span style="color:white;font-size:0.875rem;font-weight:600;letter-spacing:0.05em;background:rgba(0,0,0,0.5);backdrop-filter:blur(8px);padding:0.375rem 0.875rem;border-radius:999px;border:1px solid rgba(255,255,255,0.2)">
              {p.label} ↗
            </span>
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<style>
  @media (max-width: 767px) { #masonry-grid { columns: 1 !important; } }
  @media (min-width: 768px) and (max-width: 1023px) { #masonry-grid { columns: 2 !important; } }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Pasar datos al lightbox
  const proyectos = Array.from({ length: 12 }, (_, i) => ({
    src: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/images/Studio${i + 1}.webp`,
    alt: `Studio ${i + 1} — Proyecto acústico Acústica Superior`,
  }));

  document.querySelectorAll('.proyecto-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = parseInt((btn as HTMLElement).dataset.index || '0');
      (window as any).__openLightbox(index, proyectos);
    });
  });

  gsap.from('.proyecto-item', {
    y: 30,
    opacity: 0,
    stagger: 0.06,
    duration: 0.6,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '#masonry-grid',
      start: 'top 85%',
    }
  });
</script>
