---
import Lightbox from './Lightbox.astro';

const proyectos = Array.from({ length: 12 }, (_, i) => ({
  src: `/images/Studio${i + 1}.webp`,
  alt: `Studio ${i + 1} — Proyecto acústico Acústica Superior`,
  label: `Studio ${i + 1}`,
}));
---
<Lightbox />

<section class="py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div id="masonry-grid" style="columns: 3; column-gap: 1rem;">
      {proyectos.map((p, i) => (
        <button
          class="proyecto-item w-full mb-4 block overflow-hidden rounded-xl group relative cursor-pointer"
          style="border: 1px solid rgba(255,255,255,0.08); break-inside: avoid"
          data-index={i}
          aria-label={`Ver ${p.label}`}
        >
          <img
            src={p.src}
            alt={p.alt}
            class="w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 transition-all duration-300 flex items-center justify-center" style="background: rgba(0,0,0,0)">
            <span class="text-white text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity">{p.label} ↗</span>
          </div>
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: rgba(0,0,0,0.4)"></div>
        </button>
      ))}
    </div>
  </div>
</section>

<style>
  @media (max-width: 767px) { #masonry-grid { columns: 1 !important; } }
  @media (min-width: 768px) and (max-width: 1023px) { #masonry-grid { columns: 2 !important; } }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Pasar datos al lightbox
  const proyectos = Array.from({ length: 12 }, (_, i) => ({
    src: `/images/Studio${i + 1}.webp`,
    alt: `Studio ${i + 1} — Proyecto acústico Acústica Superior`,
  }));

  document.querySelectorAll('.proyecto-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = parseInt((btn as HTMLElement).dataset.index || '0');
      (window as any).__openLightbox(index, proyectos);
    });
  });

  gsap.from('.proyecto-item', {
    y: 30,
    opacity: 0,
    stagger: 0.06,
    duration: 0.6,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: '#masonry-grid',
      start: 'top 85%',
    }
  });
</script>
