---
import { b } from '../utils/base';
---
<section id="hero" style={`position:relative;min-height:100vh;display:flex;align-items:center;background-image:url('${b}/images/Studio1.webp');background-size:cover;background-position:center;background-attachment:fixed`}>

  <!-- Overlay — equivalente exacto al sitio original: negro 80% -->
  <div style="position:absolute;inset:0;background:rgba(0,0,0,0.8)"></div>

  <!-- Content -->
  <div style="position:relative;z-index:10;width:100%;padding-top:5rem">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem;text-align:center">
      <div class="hero-content">

        <span style="display:inline-block;font-size:0.75rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:1.5rem;padding:0.25rem 0.75rem;border-radius:9999px;color:#FD9800;border:1px solid rgba(253,152,0,0.35);background:rgba(253,152,0,0.08);font-family:'DM Sans',sans-serif">
          Tratamiento Acústico Profesional · Panamá
        </span>

        <h1 style="font-family:'Lexend',sans-serif;font-weight:600;line-height:1.12;margin-bottom:1.5rem;font-size:clamp(2.5rem,4.2vw,3.375rem);color:white;max-width:100%">
          ¡En Acústica Superior ofrecemos soluciones acústicas personalizadas para mejorar el sonido y la funcionalidad de tu espacio!
        </h1>

        <p style="font-size:1.125rem;line-height:1.75;margin-bottom:2.5rem;color:rgba(255,255,255,0.75);font-family:'DM Sans',sans-serif">
          Somos especialistas en acústica arquitectónica y tratamiento acústico.
        </p>

        <a href="https://wa.me/50761399247?text=Hola,%20quiero%20una%20cotización" target="_blank" rel="noopener" class="btn-primary" style="font-size:1rem;text-decoration:none">
          Cotiza Con Nosotros →
        </a>

      </div>
    </div>
  </div>
</section>

<style>
  /* iOS/Safari fallback: background-attachment:fixed no funciona en dispositivos touch */
  @supports (-webkit-overflow-scrolling: touch) {
    #hero { background-attachment: scroll !important; }
  }
  @media (max-width: 767px) {
    #hero {
      background-attachment: scroll !important;
    }
    #hero > div:last-child {
      padding-top: 6rem !important;
      padding-bottom: 3rem !important;
    }
    .hero-content h1 {
      font-size: clamp(1.75rem, 6vw, 2.4rem) !important;
      line-height: 1.2 !important;
    }
    .hero-content p {
      font-size: 1rem !important;
    }
    .hero-content a {
      width: 100% !important;
      justify-content: center !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.hero-content > *', {
    y: 30,
    opacity: 0,
    duration: 0.9,
    stagger: 0.15,
    ease: 'power3.out',
    delay: 0.2,
  });
</script>
