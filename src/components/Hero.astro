---
import { b } from '../utils/base';
---
<section id="hero" style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden">

  <!-- BG image fullscreen -->
  <div style="position:absolute;inset:0">
    <img
      src={`${b}/images/Studio1.webp`}
      alt=""
      style="width:100%;height:100%;object-fit:cover;object-position:center"
      loading="eager"
    />
    <!-- Capa 1: oscurecimiento base uniforme -->
    <div style="position:absolute;inset:0;background:rgba(8,8,8,0.55)"></div>
    <!-- Capa 2: gradient vertical — cielo abierto arriba, negro sólido abajo -->
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(8,8,8,0.2) 0%,rgba(8,8,8,0.98) 80%)"></div>
    <!-- Capa 3: gradient lateral sutil — izquierda oscura para legibilidad del texto -->
    <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(8,8,8,0.3) 0%,transparent 55%)"></div>
  </div>

  <!-- Ambient glow blobs — muy sutiles, no prominentes -->
  <div style="position:absolute;inset:0;pointer-events:none;overflow:hidden">
    <div style="position:absolute;width:700px;height:700px;background:radial-gradient(circle,rgba(253,232,23,0.06) 0%,transparent 65%);top:-200px;left:-150px"></div>
    <div style="position:absolute;width:500px;height:500px;background:radial-gradient(circle,rgba(253,232,23,0.08) 0%,transparent 65%);bottom:-100px;right:-50px"></div>
  </div>

  <!-- Content -->
  <div style="position:relative;z-index:10;width:100%;padding-top:5rem">
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem">
      <div class="hero-content" style="max-width:44rem">

        <span style="display:inline-block;font-size:0.75rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:1.5rem;padding:0.25rem 0.75rem;border-radius:9999px;color:#FDE817;border:1px solid rgba(253,232,23,0.25);background:rgba(253,232,23,0.05)">
          Tratamiento Acústico Profesional · Panamá
        </span>

        <h1 style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;line-height:1.05;margin-bottom:1.5rem;font-size:clamp(2.8rem,6vw,5rem);color:white">
          Transformamos<br>
          <span class="text-gradient">Espacios en</span><br>
          Sonido.
        </h1>

        <p style="font-size:1.125rem;line-height:1.75;margin-bottom:2.5rem;max-width:32rem;color:rgba(255,255,255,0.55)">
          Diseño acústico personalizado para estudios de grabación, salas de reunión y espacios corporativos. Precisión técnica con estética superior.
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:1rem">
          <a href="https://wa.me/50761399247?text=Hola,%20quiero%20una%20cotización" target="_blank" rel="noopener" class="btn-primary" style="font-size:1rem;text-decoration:none">
            Solicitar Cotización →
          </a>
          <a href={`${b}/proyectos`}
            style="display:inline-flex;align-items:center;gap:0.5rem;color:white;padding:0.875rem 1.75rem;border-radius:8px;font-weight:600;transition:border-color 0.2s;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.03);text-decoration:none;font-family:'Inter',sans-serif;font-size:0.9375rem"
            onmouseenter="this.style.borderColor='rgba(255,255,255,0.3)'"
            onmouseleave="this.style.borderColor='rgba(255,255,255,0.12)'">
            Ver Proyectos ↓
          </a>
        </div>

        <!-- Separador + mini stats -->
        <div style="margin-top:3rem;display:flex;align-items:center;gap:1.5rem;border-top:1px solid rgba(255,255,255,0.08);padding-top:1.5rem">
          <div style="text-align:center">
            <div style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;font-size:1.5rem;color:#FDE817">12+</div>
            <div style="font-size:0.75rem;margin-top:0.125rem;color:rgba(255,255,255,0.4)">Proyectos</div>
          </div>
          <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.1)"></div>
          <div style="text-align:center">
            <div style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;font-size:1.5rem;color:#FDE817">5</div>
            <div style="font-size:0.75rem;margin-top:0.125rem;color:rgba(255,255,255,0.4)">Servicios</div>
          </div>
          <div style="width:1px;height:2.5rem;background:rgba(255,255,255,0.1)"></div>
          <div style="text-align:center">
            <div style="font-family:'Plus Jakarta Sans',sans-serif;font-weight:900;font-size:1.5rem;color:#FDE817">100%</div>
            <div style="font-size:0.75rem;margin-top:0.125rem;color:rgba(255,255,255,0.4)">Garantizado</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.hero-content > *', {
    y: 30,
    opacity: 0,
    duration: 0.9,
    stagger: 0.15,
    ease: 'power3.out',
    delay: 0.2,
  });
</script>
